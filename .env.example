# 反馈 API 根地址（构建时打入安装包；打包前复制为 .env 或在本机设置同名变量）

MAIN_VITE_FEEDBACK_API_URL=https://wannian.fun



# 可选：运行时的 OS 级覆盖（一般仅运维/调试使用，不会随安装包带给用户）

# HANSTUDY_FEEDBACK_API=https://wannian.fun



# 运行环境：安装包默认为 user（用户环境）；npm run dev 默认为 test（测试环境）

# HANSTUDY_PROFILE=user



# Java 后端端口：用户环境 17890，测试环境 17891（npm run dev 自动使用 17891）

# HANSTUDY_JAVA_PORT=17891

