{
  "name": "hanstudy-reader",
  "version": "0.1.0",
  "description": "Document reader with notes and AI — VS Code style layout",
  "main": "./out/main/index.js",
  "author": "HAN",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build:java && electron-vite dev",
    "dev:java": "cd java-backend && mvnw.cmd -q exec:java",
    "build:java": "cd java-backend && mvnw.cmd -q package -DskipTests",
    "prepare:jre": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fetch-jre.ps1",
    "verify:packaging": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-packaging.ps1",
    "typecheck": "tsc -p tsconfig.web.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:all": "npm run typecheck && vitest run",
    "test:webview": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-webview.ps1",
    "build": "npm run build:java && electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run prepare:jre && npm run verify:packaging && npm run build && electron-builder",
    "dist:win": "npm run prepare:jre && npm run verify:packaging && npm run build && electron-builder --win"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "allotment": "^1.20.2",
    "dompurify": "^3.2.4",
    "lucide-react": "^1.17.0",
    "mammoth": "^1.9.0",
    "marked": "^18.0.5",
    "monaco-editor": "^0.52.2",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "happy-dom": "^20.10.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.14",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "com.hanstudy.reader",
    "productName": "HAN Study Reader",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "asarUnpack": [
      "node_modules/pdfjs-dist/**"
    ],
    "extraResources": [
      {
        "from": "java-backend/target/hanstudy-backend.jar",
        "to": "java/hanstudy-backend.jar"
      },
      {
        "from": "resources/skills",
        "to": "skills",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HAN Study Reader"
    }
  }
}
